# 登录会话签名（生产环境务必修改）
AUTH_SECRET=your-random-secret

# Supabase（Vercel 部署必填；本地开发可不填，自动使用 data/ 目录）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 服务端密钥（二选一，不要用 publishable key）
# Legacy: Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# 新版: Project Settings → API Keys → Secret key
# SUPABASE_SECRET_KEY=sb_secret_...

# 以下仅供前端直连 Supabase 时使用，当前项目服务端上传不需要
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# OCR / AI（按需配置）
# VOLCENGINE_API_KEY=
# AUTO_REVIEW_ENABLED=true
