# 火山方舟图文识别（Responses API）
# 配置文档：https://www.volcengine.com/docs/82379/1399008
ARK_API_KEY=your_ark_api_key

# 模型 ID，默认 doubao-seed-2-0-pro-260215（追求速度可换 lite/mini）
# ARK_VISION_MODEL=doubao-seed-2-0-pro-260215

# 深度思考：disabled 关闭（推荐，单据 OCR 更快）| enabled | auto
# ARK_THINKING_TYPE=disabled

# 截图识别最大输出 token（入库多行表默认 16384，计量单默认 4096）
# ARK_MAX_OUTPUT_TOKENS_INBOUND=16384
# ARK_MAX_OUTPUT_TOKENS_MEASURE=4096

# AI 自动核对：计量单仅置信度 100% 自动通过，否则需复核
# AUTO_REVIEW_ENABLED=true
# AUTO_REVIEW_CONFIDENCE=100
# AUTO_REVIEW_EXCEL_INBOUND=true
# 入库单截图：字段完整度 + 识别置信度达标则自动通过（减少人工复核）
# AUTO_REVIEW_INBOUND_IMAGE=true
# AUTO_REVIEW_INBOUND_IMAGE_MIN_SCORE=85
# AUTO_REVIEW_INBOUND_IMAGE_CONFIDENCE=88

# 可选，默认 https://ark.cn-beijing.volces.com/api/v3
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
